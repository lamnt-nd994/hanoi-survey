{
  "name": "hanoi-survey-monorepo",
  "private": true,
  "workspaces": [
    "apps/web-client",
    "apps/admin-portal"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web-client",
    "dev:admin": "npm run dev --workspace admin-portal",
    "build:web": "npm run build --workspace web-client",
    "build:admin": "npm run build --workspace admin-portal",
    "build": "npm run build:web && npm run build:admin"
  }
}
